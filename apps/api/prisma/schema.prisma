generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

enum UserType {
  INTERNAL
  OWNER
  TENANT
  VENDOR
  SYSTEM
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  MIXED_USE
  INDUSTRIAL
  LAND
  OTHER
}

enum OccupancyStatus {
  VACANT
  OCCUPIED
  RESERVED
  UNAVAILABLE
}

enum DocumentIngestionStatus {
  UPLOADED
  PENDING
  PROCESSING
  READY
  FAILED
  REPROCESSING_REQUESTED
}

enum DocumentLinkedEntityType {
  PROPERTY
  OWNER
  VENDOR
}

enum CommunicationChannelType {
  EMAIL
  PHONE
  PORTAL
  SMS
  INTERNAL
}

enum CommunicationThreadStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum CommunicationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum OperationalPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
  CANCELLED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum WorkOrderStatus {
  OPEN
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InvoiceApprovalStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum AccountingExportStatus {
  EXPORT_REQUESTED
  EXPORTED_MOCK
  EXPORT_FAILED
}

enum ApprovalTargetEntityType {
  INVOICE
}

enum ApprovalFlowStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum ApprovalStepStatus {
  PENDING
  COMPLETED
}

enum ApprovalDecision {
  APPROVE
  REJECT
  REQUEST_CHANGES
}

enum WorkflowStatus {
  RUNNING
  WAITING
  COMPLETED
  FAILED
  CANCELLED
}

enum WorkflowOrchestrationProvider {
  TEMPORAL_STUB
  TEMPORAL
}

model Organization {
  id          String                @id @default(uuid())
  name        String
  slug        String                @unique
  status      OrganizationStatus    @default(ACTIVE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  users       User[]
  roles       Role[]
  auditEvents AuditEvent[]
  properties  Property[]
  owners      Owner[]
  vendors     Vendor[]
  documents   Document[]
  communicationThreads CommunicationThread[]
  cases       Case[]
  tasks       Task[]
  invoices    Invoice[]
  approvalFlows ApprovalFlow[]
  workflowRuns WorkflowRun[]
}

model User {
  id                   String               @id @default(uuid())
  organizationId       String
  email                String               @unique
  passwordHash         String
  firstName            String
  lastName             String
  userType             UserType             @default(INTERNAL)
  status               UserStatus           @default(ACTIVE)
  lastLoginAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleAssignments      UserRoleAssignment[]
  actorForAuditEvents  AuditEvent[]         @relation("AuditActor")
  managedProperties    Property[]           @relation("PropertyManager")
  uploadedDocuments    Document[]           @relation("DocumentUploadedBy")
  createdCommunicationThreads CommunicationThread[] @relation("ThreadCreatedBy")
  assignedCommunicationThreads CommunicationThread[] @relation("ThreadAssignedTo")
  createdCases        Case[]                @relation("CaseCreatedBy")
  assignedCases       Case[]                @relation("CaseAssignedTo")
  assignedTasks       Task[]                @relation("TaskAssignedTo")
  initiatedApprovalFlows ApprovalFlow[]     @relation("ApprovalFlowInitiatedBy")

  @@index([organizationId])
}

model Role {
  id               String               @id @default(uuid())
  organizationId   String
  roleName         String
  description      String?
  createdAt        DateTime             @default(now())
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userAssignments  UserRoleAssignment[]
  rolePermissions  RolePermission[]

  @@unique([organizationId, roleName])
  @@index([organizationId])
}

model Permission {
  id              String           @id @default(uuid())
  permissionName  String           @unique
  description     String?
  rolePermissions RolePermission[]
}

model UserRoleAssignment {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model AuditEvent {
  id             String       @id @default(uuid())
  organizationId String
  actorUserId    String?
  actionType     String
  entityType     String
  entityId       String?
  oldValues      Json?
  newValues      Json?
  metadata       Json?
  occurredAt     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser      User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([actorUserId])
  @@index([actionType])
  @@index([entityType, entityId])
}

model Property {
  id             String         @id @default(uuid())
  organizationId String
  propertyCode   String
  name           String
  street         String?
  city           String?
  postalCode     String?
  countryCode    String?
  status         PropertyStatus @default(ACTIVE)
  propertyType   PropertyType
  managerUserId  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  managerUser    User?          @relation("PropertyManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  buildings      Building[]
  units          Unit[]
  ownerLinks     PropertyOwnerLink[]
  cases          Case[]
  invoices       Invoice[]

  @@unique([organizationId, propertyCode])
  @@index([organizationId])
  @@index([managerUserId])
}

model Building {
  id           String   @id @default(uuid())
  propertyId   String
  name         String?
  buildingCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  units        Unit[]

  @@unique([propertyId, buildingCode])
  @@index([propertyId])
}

model Unit {
  id              String          @id @default(uuid())
  propertyId      String
  buildingId      String?
  unitNumber      String
  floorLabel      String?
  unitType        String?
  squareMeters    Float?
  bedroomCount    Int?
  bathroomCount   Float?
  occupancyStatus OccupancyStatus @default(VACANT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  property        Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  building        Building?       @relation(fields: [buildingId], references: [id], onDelete: SetNull)
  cases           Case[]

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
  @@index([buildingId])
}

model Owner {
  id             String             @id @default(uuid())
  organizationId String
  displayName    String
  email          String?
  phone          String?
  isCompany      Boolean            @default(false)
  status         UserStatus         @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  propertyLinks  PropertyOwnerLink[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([displayName])
}

model PropertyOwnerLink {
  propertyId           String
  ownerId              String
  ownershipPercentage  Float?
  startDate            DateTime?
  endDate              DateTime?
  isPrimaryContact     Boolean   @default(false)
  createdAt            DateTime  @default(now())
  property             Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner                Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@id([propertyId, ownerId])
  @@index([ownerId])
}

model Vendor {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  vendorType     String?
  email          String?
  phone          String?
  tradeCategory  String?
  serviceRegions String[]     @default([])
  taxId          String?
  status         UserStatus   @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workOrders     WorkOrder[]
  invoices       Invoice[]

  @@index([organizationId])
  @@index([tradeCategory])
  @@index([name])
}

model Document {
  id              String                  @id @default(uuid())
  organizationId  String
  storageKey      String
  fileName        String
  mimeType        String?
  fileSizeBytes   Int?
  sourceType      String?
  sourceReference String?
  documentType    String?
  ingestionStatus DocumentIngestionStatus @default(UPLOADED)
  checksumSha256  String?
  uploadedByUserId String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedByUser  User?                   @relation("DocumentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  links           DocumentLink[]
  attachments     Attachment[]
  messageAttachments MessageAttachment[]
  sourceInvoices Invoice[] @relation("InvoiceSourceDocument")

  @@index([organizationId])
  @@index([uploadedByUserId])
  @@index([documentType])
}

model DocumentLink {
  documentId       String
  linkedEntityType DocumentLinkedEntityType
  linkedEntityId   String
  linkRole         String?
  createdAt        DateTime                 @default(now())
  document         Document                 @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([documentId, linkedEntityType, linkedEntityId])
  @@index([linkedEntityType, linkedEntityId])
}

model Attachment {
  id                    String    @id @default(uuid())
  documentId            String
  attachmentContextType String
  attachmentContextId   String
  createdAt             DateTime  @default(now())
  document              Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([attachmentContextType, attachmentContextId])
}

model CommunicationThread {
  id               String                    @id @default(uuid())
  organizationId   String
  channelType      CommunicationChannelType
  subject          String?
  status           CommunicationThreadStatus @default(OPEN)
  priority         CommunicationPriority     @default(NORMAL)
  linkedEntityType DocumentLinkedEntityType?
  linkedEntityId   String?
  createdByUserId  String?
  assignedUserId   String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  organization     Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUser    User?                     @relation("ThreadCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedUser     User?                     @relation("ThreadAssignedTo", fields: [assignedUserId], references: [id], onDelete: SetNull)
  messages         Message[]

  @@index([organizationId])
  @@index([assignedUserId])
  @@index([linkedEntityType, linkedEntityId])
}

model Message {
  id                String           @id @default(uuid())
  threadId          String
  direction         MessageDirection @default(OUTBOUND)
  senderType        String?
  senderReferenceId String?
  bodyText          String?
  bodyHtml          String?
  messageStatus     String?
  receivedAt        DateTime?
  sentAt            DateTime?
  createdAt         DateTime         @default(now())
  thread            CommunicationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments       MessageAttachment[]

  @@index([threadId])
}

model MessageAttachment {
  messageId   String
  documentId  String
  createdAt   DateTime @default(now())
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([messageId, documentId])
  @@index([documentId])
}

model Case {
  id                 String            @id @default(uuid())
  organizationId     String
  propertyId         String?
  unitId             String?
  caseType           String
  title              String
  description        String?
  status             CaseStatus        @default(OPEN)
  priority           OperationalPriority @default(NORMAL)
  openedAt           DateTime          @default(now())
  dueAt              DateTime?
  closedAt           DateTime?
  createdByUserId    String?
  assignedUserId     String?
  ownerVisibleStatus String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property           Property?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  unit               Unit?             @relation(fields: [unitId], references: [id], onDelete: SetNull)
  createdByUser      User?             @relation("CaseCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedUser       User?             @relation("CaseAssignedTo", fields: [assignedUserId], references: [id], onDelete: SetNull)
  workOrders         WorkOrder[]

  @@index([organizationId])
  @@index([propertyId])
  @@index([assignedUserId])
}

model Task {
  id                String            @id @default(uuid())
  organizationId    String
  taskType          String
  title             String
  description       String?
  status            TaskStatus        @default(OPEN)
  priority          OperationalPriority @default(NORMAL)
  assignedUserId    String?
  relatedEntityType String?
  relatedEntityId   String?
  dueAt             DateTime?
  completedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUser      User?             @relation("TaskAssignedTo", fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([assignedUserId])
}

model WorkOrder {
  id              String         @id @default(uuid())
  caseId          String
  vendorId        String?
  workOrderNumber String
  description     String?
  status          WorkOrderStatus @default(OPEN)
  scheduledFor    DateTime?
  completedAt     DateTime?
  slaDueAt        DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  case            Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  vendor          Vendor?        @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@unique([caseId, workOrderNumber])
  @@index([vendorId])
  @@index([caseId])
}

model Invoice {
  id                   String               @id @default(uuid())
  organizationId       String
  propertyId           String?
  vendorId             String?
  sourceDocumentId     String?
  invoiceNumber        String?
  invoiceDate          DateTime?
  dueDate              DateTime?
  currencyCode         String
  subtotalAmount       Decimal?             @db.Decimal(14, 2)
  taxAmount            Decimal?             @db.Decimal(14, 2)
  totalAmount          Decimal?             @db.Decimal(14, 2)
  extractionConfidence Float?
  duplicateCheckStatus String?
  approvalStatus       InvoiceApprovalStatus @default(DRAFT)
  accountingExportStatus AccountingExportStatus?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property             Property?            @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  vendor               Vendor?              @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  sourceDocument       Document?            @relation("InvoiceSourceDocument", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  lines                InvoiceLine[]

  @@unique([organizationId, vendorId, invoiceNumber])
  @@index([organizationId])
  @@index([propertyId])
  @@index([vendorId])
  @@index([sourceDocumentId])
  @@index([approvalStatus])
}

model InvoiceLine {
  id          String   @id @default(uuid())
  invoiceId   String
  lineNumber  Int
  description String?
  quantity    Decimal? @db.Decimal(14, 3)
  unitPrice   Decimal? @db.Decimal(14, 2)
  lineTotal   Decimal? @db.Decimal(14, 2)
  taxRate     Decimal? @db.Decimal(7, 4)
  createdAt   DateTime @default(now())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, lineNumber])
  @@index([invoiceId])
}

model ApprovalFlow {
  id               String               @id @default(uuid())
  organizationId   String
  targetEntityType ApprovalTargetEntityType
  targetEntityId   String
  flowType         String
  status           ApprovalFlowStatus   @default(PENDING)
  initiatedByUserId String?
  startedAt        DateTime             @default(now())
  completedAt      DateTime?
  createdAt        DateTime             @default(now())
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  initiatedByUser  User?                @relation("ApprovalFlowInitiatedBy", fields: [initiatedByUserId], references: [id], onDelete: SetNull)
  steps            ApprovalStep[]

  @@index([organizationId])
  @@index([targetEntityType, targetEntityId])
}

model ApprovalStep {
  id             String             @id @default(uuid())
  approvalFlowId String
  stepOrder      Int
  approverUserId String?
  approverRole   String?
  status         ApprovalStepStatus @default(PENDING)
  decision       ApprovalDecision?
  decisionReason String?
  actedAt        DateTime?
  createdAt      DateTime           @default(now())
  approvalFlow   ApprovalFlow       @relation(fields: [approvalFlowId], references: [id], onDelete: Cascade)

  @@unique([approvalFlowId, stepOrder])
  @@index([approvalFlowId])
}

model WorkflowRun {
  id                    String                        @id @default(uuid())
  organizationId        String
  workflowType          String
  targetEntityType      String?
  targetEntityId        String?
  orchestrationProvider WorkflowOrchestrationProvider
  orchestrationRunId    String?
  status                WorkflowStatus                @default(RUNNING)
  startedAt             DateTime                      @default(now())
  completedAt           DateTime?
  lastHeartbeatAt       DateTime?
  createdAt             DateTime                      @default(now())
  organization          Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events                WorkflowEvent[]

  @@index([organizationId])
  @@index([workflowType])
  @@index([status])
  @@index([targetEntityType, targetEntityId])
}

model WorkflowEvent {
  id           String      @id @default(uuid())
  workflowRunId String
  eventType    String
  eventPayload Json?
  createdAt    DateTime    @default(now())
  workflowRun  WorkflowRun @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([workflowRunId])
}
