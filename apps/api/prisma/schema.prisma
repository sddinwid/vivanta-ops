generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

enum UserType {
  INTERNAL
  OWNER
  TENANT
  VENDOR
  SYSTEM
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
}

enum PropertyStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  MIXED_USE
  INDUSTRIAL
  LAND
  OTHER
}

enum OccupancyStatus {
  VACANT
  OCCUPIED
  RESERVED
  UNAVAILABLE
}

enum DocumentIngestionStatus {
  UPLOADED
  PENDING
  PROCESSING
  READY
  FAILED
  REPROCESSING_REQUESTED
}

enum DocumentLinkedEntityType {
  PROPERTY
  OWNER
  VENDOR
}

model Organization {
  id          String                @id @default(uuid())
  name        String
  slug        String                @unique
  status      OrganizationStatus    @default(ACTIVE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  users       User[]
  roles       Role[]
  auditEvents AuditEvent[]
  properties  Property[]
  owners      Owner[]
  vendors     Vendor[]
  documents   Document[]
}

model User {
  id                   String               @id @default(uuid())
  organizationId       String
  email                String               @unique
  passwordHash         String
  firstName            String
  lastName             String
  userType             UserType             @default(INTERNAL)
  status               UserStatus           @default(ACTIVE)
  lastLoginAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  roleAssignments      UserRoleAssignment[]
  actorForAuditEvents  AuditEvent[]         @relation("AuditActor")
  managedProperties    Property[]           @relation("PropertyManager")
  uploadedDocuments    Document[]           @relation("DocumentUploadedBy")

  @@index([organizationId])
}

model Role {
  id               String               @id @default(uuid())
  organizationId   String
  roleName         String
  description      String?
  createdAt        DateTime             @default(now())
  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userAssignments  UserRoleAssignment[]
  rolePermissions  RolePermission[]

  @@unique([organizationId, roleName])
  @@index([organizationId])
}

model Permission {
  id              String           @id @default(uuid())
  permissionName  String           @unique
  description     String?
  rolePermissions RolePermission[]
}

model UserRoleAssignment {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model AuditEvent {
  id             String       @id @default(uuid())
  organizationId String
  actorUserId    String?
  actionType     String
  entityType     String
  entityId       String?
  oldValues      Json?
  newValues      Json?
  metadata       Json?
  occurredAt     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser      User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, occurredAt])
  @@index([actorUserId])
  @@index([actionType])
  @@index([entityType, entityId])
}

model Property {
  id             String         @id @default(uuid())
  organizationId String
  propertyCode   String
  name           String
  street         String?
  city           String?
  postalCode     String?
  countryCode    String?
  status         PropertyStatus @default(ACTIVE)
  propertyType   PropertyType
  managerUserId  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  managerUser    User?          @relation("PropertyManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  buildings      Building[]
  units          Unit[]
  ownerLinks     PropertyOwnerLink[]

  @@unique([organizationId, propertyCode])
  @@index([organizationId])
  @@index([managerUserId])
}

model Building {
  id           String   @id @default(uuid())
  propertyId   String
  name         String?
  buildingCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  units        Unit[]

  @@unique([propertyId, buildingCode])
  @@index([propertyId])
}

model Unit {
  id              String          @id @default(uuid())
  propertyId      String
  buildingId      String?
  unitNumber      String
  floorLabel      String?
  unitType        String?
  squareMeters    Float?
  bedroomCount    Int?
  bathroomCount   Float?
  occupancyStatus OccupancyStatus @default(VACANT)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  property        Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  building        Building?       @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  @@unique([propertyId, unitNumber])
  @@index([propertyId])
  @@index([buildingId])
}

model Owner {
  id             String             @id @default(uuid())
  organizationId String
  displayName    String
  email          String?
  phone          String?
  isCompany      Boolean            @default(false)
  status         UserStatus         @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  propertyLinks  PropertyOwnerLink[]

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([displayName])
}

model PropertyOwnerLink {
  propertyId           String
  ownerId              String
  ownershipPercentage  Float?
  startDate            DateTime?
  endDate              DateTime?
  isPrimaryContact     Boolean   @default(false)
  createdAt            DateTime  @default(now())
  property             Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  owner                Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@id([propertyId, ownerId])
  @@index([ownerId])
}

model Vendor {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  vendorType     String?
  email          String?
  phone          String?
  tradeCategory  String?
  serviceRegions String[]     @default([])
  taxId          String?
  status         UserStatus   @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([tradeCategory])
  @@index([name])
}

model Document {
  id              String                  @id @default(uuid())
  organizationId  String
  storageKey      String
  fileName        String
  mimeType        String?
  fileSizeBytes   Int?
  sourceType      String?
  sourceReference String?
  documentType    String?
  ingestionStatus DocumentIngestionStatus @default(UPLOADED)
  checksumSha256  String?
  uploadedByUserId String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedByUser  User?                   @relation("DocumentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  links           DocumentLink[]
  attachments     Attachment[]

  @@index([organizationId])
  @@index([uploadedByUserId])
  @@index([documentType])
}

model DocumentLink {
  documentId       String
  linkedEntityType DocumentLinkedEntityType
  linkedEntityId   String
  linkRole         String?
  createdAt        DateTime                 @default(now())
  document         Document                 @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([documentId, linkedEntityType, linkedEntityId])
  @@index([linkedEntityType, linkedEntityId])
}

model Attachment {
  id                    String    @id @default(uuid())
  documentId            String
  attachmentContextType String
  attachmentContextId   String
  createdAt             DateTime  @default(now())
  document              Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([attachmentContextType, attachmentContextId])
}
