{
  "name": "vivanta-ops",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "db:generate": "pnpm --filter @vivanta/api prisma:generate",
    "db:migrate": "pnpm --filter @vivanta/api prisma:migrate",
    "db:seed": "pnpm --filter @vivanta/api prisma:seed"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
